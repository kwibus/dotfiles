# Power off displays after 5 min idle; restore on activity/resume
timeout 300 'swaymsg "output * power off"' resume 'swaymsg "output * power on"'
after-resume 'swaymsg "output * power on"'

# Lock after 6 min idle
timeout 360 'swaylock -f'

# Suspend after 10 min idle. swayidle honours Wayland idle-inhibitors
# (games/video that request "no idle"); logind IdleAction is now off.
timeout 600 'systemctl suspend'

# # Always lock before sleep (guard against stacking a second swaylock)
# # and when the session is locked (loginctl lock-session).
# before-sleep 'pgrep -x swaylock >/dev/null || swaylock -f'
lock 'swaylock -f'
idlehint 100
